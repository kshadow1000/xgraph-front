socket(AF_INET,SOCK_STREAM,IPPROTO_TCP)-->fd;
const(p,byte(16));
bzero(p,16);
w16(p,AF_INET);
w16(p#2,htons(12345));
bind(fd,p,16);
listen(fd,1);
0-->rfd;
while(accept(fd,0,0)->rfd>=0){
	const(b,byte(8*1024*1024));
	var(sz);
	while(read(rfd,b,8*1024*1024)->sz>0){
		write(rfd,b,sz);
	};
	close(rfd);
};
close(fd);
